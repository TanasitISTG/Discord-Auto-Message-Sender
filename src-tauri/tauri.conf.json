{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Discord Auto Message Sender",
  "version": "0.1.0",
  "identifier": "com.local.discord-auto-message-sender",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Discord Auto Message Sender",
        "width": 1480,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
