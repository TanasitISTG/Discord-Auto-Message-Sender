                { "name": "envPath", "type": "string" },
                { "name": "configPath", "type": "string" },
                { "name": "statePath", "type": "string" },
                { "name": "logsDir", "type": "string" },
                { "name": "warning", "type": "string", "optional": true }
            ]
        }
