{
  "name": "discord-auto-message-sender",
  "version": "1.0.0",
  "description": "Local-first desktop app for configuring and running repeated Discord message sessions.",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build --config vite.config.mts",
    "build:core": "tsc -p tsconfig.json",
    "build:sidecar": "bun run ./scripts/build-sidecar.ts",
    "dev": "vite --config vite.config.mts",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "release:version-check": "bun run ./scripts/check-versions.ts",
    "release:check": "bun run typecheck && bun run test && cargo test --manifest-path src-tauri/Cargo.toml && bun run desktop:build && bun run smoke:desktop && bun run release:version-check",
    "smoke:desktop": "bun run ./scripts/smoke-packaged-app.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p app/tsconfig.json",
    "test:core": "node scripts/run-tests.js",
    "test:ui": "vitest run --config vitest.config.mts",
    "test": "bun run test:core && bun run test:ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-select": "^2.2.6",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
