{
    "name": "discord-auto-message-sender",
    "version": "1.0.0",
    "description": "Local-first desktop app for configuring and running repeated Discord message sessions.",
    "main": "index.js",
    "scripts": {
        "build": "tsc -p tsconfig.json && vite build --config vite.config.mts",
        "build:core": "tsc -p tsconfig.json",
        "build:sidecar": "bun run ./scripts/build-sidecar.ts",
        "contracts:generate": "bun run ./scripts/generate-desktop-contracts.ts --write",
        "contracts:check": "bun run ./scripts/generate-desktop-contracts.ts --check",
        "dev": "vite --config vite.config.mts",
        "desktop:dev": "tauri dev",
        "desktop:build": "tauri build",
        "format:web": "prettier . --write",
        "format:web:check": "prettier . --check .",
        "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
        "format:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all --check",
        "format": "bun run format:web && bun run format:rust",
        "format:check": "bun run format:web:check && bun run format:rust:check",
        "lint:eslint": "eslint .",
        "lint:eslint:fix": "eslint . --fix",
        "lint:boundaries": "bun run ./scripts/check-boundaries.ts",
        "lint:file-sizes": "bun run ./scripts/check-file-sizes.ts",
        "lint:architecture": "bun run lint:boundaries && bun run lint:file-sizes",
        "lint": "bun run lint:eslint && bun run lint:architecture",
        "release:version-check": "bun run ./scripts/check-versions.ts",
        "release:check": "bun run lint && bun run format:check && bun run contracts:check && bun run typecheck && bun run test && cargo test --manifest-path src-tauri/Cargo.toml && bun run desktop:build && bun run smoke:desktop && bun run release:version-check",
        "smoke:desktop": "bun run ./scripts/smoke-packaged-app.ts",
        "typecheck": "bun run contracts:check && tsc --noEmit -p tsconfig.json && tsc --noEmit -p app/tsconfig.json",
        "test:core": "bun run contracts:check && node scripts/run-tests.js",
        "test:ui": "vitest run --config vitest.config.mts",
        "test": "bun run test:core && bun run test:ui"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "packageManager": "bun@1.3.11",
    "dependencies": {
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-select": "^2.2.6",
        "@tailwindcss/vite": "^4.2.2",
        "@tauri-apps/api": "^2.10.1",
        "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
        "@types/bun": "^1.3.11",
        "@types/node": "^25.5.0",
        "chalk": "^5.6.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dotenv": "^17.3.1",
        "lucide-react": "^0.577.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@tauri-apps/cli": "^2.10.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "jsdom": "^29.0.1",
        "postcss": "^8.5.8",
        "prettier": "^3.8.1",
        "tailwindcss": "^4.2.2",
        "typescript-eslint": "^8.58.0",
        "vite": "^8.0.1",
        "vitest": "^4.1.0"
    }
}
