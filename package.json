{
  "name": "discord-auto-message-sender",
  "version": "1.0.0",
  "description": "Local-first desktop app for configuring and running repeated Discord message sessions.",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build --config vite.config.mts",
    "build:core": "tsc -p tsconfig.json",
    "configure": "ts-node src/bot.ts --configure",
    "dev": "vite --config vite.config.mts",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "start": "ts-node src/bot.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p app/tsconfig.json",
    "test": "node scripts/run-tests.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "packageManager": "bun@1.3.6",
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@types/inquirer": "^8.2.5",
    "@types/node": "^25.0.3",
    "chalk": "^4.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "inquirer": "^8.2.5",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "vite": "^5.4.11"
  }
}
